{
  "name": "moneycontrol-rn-app",
  "version": "1.6.3",
  "scripts": {
    "android": "expo start --android",
    "ios": "expo start --ios",
    "start": "expo start",
    "start:local": "EXPO_PUBLIC_API_URL=http://127.0.0.1:8000 expo start",
    "lint": "eslint \"**/*.{js,jsx,ts,tsx}\" && prettier -c \"**/*.{js,jsx,ts,tsx,json}\"",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
    "test:static": "node --test tests/static/*.test.mjs",
    "test:e2e": "playwright test",
    "web": "expo start --web",
    "web:local": "EXPO_PUBLIC_API_URL=http://127.0.0.1:8000 expo start --web",
    "build:web": "expo export -p web",
    "build:android": "eas build --profile production --platform android"
  },
  "dependencies": {
    "@eva-design/eva": "^2.2.0",
    "@expo/metro-runtime": "~55.0.11",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.7",
    "@react-navigation/stack": "^6.3.17",
    "@ui-kitten/components": "^5.3.1",
    "@ui-kitten/eva-icons": "^5.3.1",
    "@ui-kitten/moment": "^5.3.1",
    "axios": "^1.7.4",
    "expo": "^55.0.24",
    "expo-clipboard": "~55.0.13",
    "expo-font": "~55.0.7",
    "expo-haptics": "~55.0.14",
    "expo-image-picker": "~55.0.20",
    "expo-linear-gradient": "~55.0.14",
    "expo-status-bar": "~55.0.6",
    "expo-updates": "~55.0.22",
    "moment": "^2.30.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-redux": "^7.2.6",
    "redux": "^4.1.2",
    "redux-devtools-extension": "^2.13.9",
    "redux-thunk": "^2.4.1",
    "reselect": "^4.1.5"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@playwright/test": "^1.60.0",
    "@types/react": "~19.2.10",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "eslint-config-universe": "^15.0.4",
    "husky": "^9.1.4",
    "lint-staged": "^15.2.8",
    "prettier": "^3.2.5",
    "typescript": "~5.9.2"
  },
  "eslintConfig": {
    "extends": "universe/native",
    "root": true
  },
  "main": "node_modules/expo/AppEntry.js",
  "private": true,
  "overrides": {
    "postcss": "^8.5.14"
  }
}
